#!/bin/sh
. "$(dirname "$0")/_/husky.sh"

# Run dotnet format only on staged .cs files
STAGED_CS=$(git diff --cached --name-only --diff-filter=ACM | grep -E "\.cs$" | tr '\n' ' ')
if [ -n "$STAGED_CS" ]; then
  dotnet format ExercisesCSharp.slnx --verify-no-changes --no-restore --include $STAGED_CS
fi

# Always run build via task runner
dotnet husky run --name dotnet-build
